- content_for(:title) { 'Journal' }

- Comment.where(created_at: 1.day.ago..).each do |comment|
  .alert.alert-primary.alert-dismissible.fade.show{ role: 'alert' }
    %strong #{comment.user.name}:
    = link_to comment.body, comment.post, class: 'text-decoration-none'
    %button.btn-close{ 'data-bs-dismiss': 'alert', 'aria-label': 'close' }

- content_for :sidebar do

  .d-grid.gap-2
    = form_with model: Entry.new do |f|
      = f.submit "+ New Journal Entry", class: 'btn btn-success w-100'
    - if Current.user.parent?
      = link_to "+ New Kids Entries", [:new, :entry_batch], class: 'btn btn-success'
      - Current.user.users_whose_entries_i_can_edit.each do |user|
        - if user.color.present?
          - style = "background-color: #{user.color}; color: #{user.contrast_color}"
        - else
          - style = 'background-color: #ffc107; color: black'
        = link_to entries_path(entry_search: { user_id: user.id }), class: 'btn', style: style do
          %i.bi-book
          #{user.name}'s Journal
      = link_to :print_batches, class: 'btn btn-info' do
        %i.bi-printer
        Print by Year

  %hr
  %h3 Search
  = form_with model: @entry_search, url: :entries, method: :get do |f|
    .mb-3
      = f.label :user
      = f.select :user_id, Current.user.users_whose_entries_i_can_edit.map { |user| [user.name, user.id] }, {}, { class: 'form-control' }
    .mb-3.row
      .col.6
        = f.label :ends_on, 'Date'
        = f.date_field :ends_on, class: 'form-control'
      .col.6
        = f.label :age, "Age"
        = f.text_field :age, placeholder: 'Years', class: 'form-control'
    .mb-3
      = f.label :tag
      = f.select :tag, Entry.tags.pluck(:name),
        { include_blank: 'Any tag' }, { class: 'form-control' }
    .form-check
      = f.check_box :random, class: 'form-check-input', id: 'search-random-checkbox'
      = f.label :random, class: 'form-check-label', for: 'search-random-checkbox'
    .mb-3
      = f.label :term
      = f.text_field :term, class: 'form-control', placeholder: 'Search'
    .mb-3.d-grid.gap-2
      = f.submit 'Search', class: 'btn btn-primary'

  %hr
  = render partial: 'shared/calendar', locals: { starts_at: @entry_search.user.born_at, resource: :entries }

- if @entry_search.entries.empty?
  .alert.alert-warning
    %h2 No results found
    %p Maybe search for something else?
- else
  - page_photos = []
  - previous_at = nil
  - @entry_search.entries.each do |entry|
    - if @entry_search.tag.present?
      %p.text-center
        = pluralize((previous_at.to_date - entry.at.to_date).to_i, 'day') if previous_at.present?
        - previous_at = entry.at
    .d-flex.justify-content-between
      %div
        %h2
          = link_to [:edit, entry], class: 'text-reset' do
            = l entry.at.to_date, format: :long
            - if entry.at != entry.at.beginning_of_day
              %small.fs-5 at #{l entry.at, format: '%l:%M%p'}
      - if entry.at < 1.week.ago
        .text-muted.text-end
          - if entry.user&.born_at.present?
            %small.d-block #{timespan(entry.user.born_at, entry.at)} old
          %small.d-block #{timespan(Time.current, entry.at)} ago
      %div
        - if entry.entry_tags.present?
          - entry.entry_tag_list.each do |tag_name|
            = link_to tag_name, entries_path(entry_search: { tag: tag_name }), class: 'badge bg-info'
    - if params[:term].present?
      %p
        &hellip;
        = highlight(excerpt(entry.body, params[:term], radius: 55), params[:term])
        &hellip;
    - else
      .mb-4
        = entry.body&.html_safe
        - photos = Photo.where(at: entry.at.all_day).order(at: :asc).tagged_with(@entry_search.user.name, on: :photo_tags)
        - if photos.present?
          - page_photos += photos
          .d-flex.flex-wrap.align-items-center= render photos

  = paginate @entry_search.entries

  - if page_photos.present?
    = render partial: "/shared/carousel_modal",
      locals: { photos: page_photos, modal_id: "photos-modal", carousel_id: "photos-carousel" }
